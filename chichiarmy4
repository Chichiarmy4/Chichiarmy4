<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Control Panel</title>
    <style>
        body { background: #121212; color: white; font-family: sans-serif; margin: 0; display: flex; flex-direction: column; height: 100vh; }
        #chat-container { flex: 1; overflow-y: auto; padding: 20px; }
        .message { background: #1e1e1e; padding: 10px; margin: 5px 0; border-radius: 10px; }
        .input-area { padding: 20px; background: #000; display: flex; }
        input { flex: 1; padding: 10px; background: #333; border: none; color: white; border-radius: 5px; }
        button { margin-left: 10px; background: #bb86fc; border: none; padding: 10px; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>

<div id="chat-container"></div>
<div class="input-area">
    <input type="text" id="userInput" placeholder="Ask anything...">
    <button onclick="sendMessage()">Send</button>
</div>

<script>
    // Load chats from phone memory
    let chatHistory = JSON.parse(localStorage.getItem('myChats')) || [];
    const chatContainer = document.getElementById('chat-container');

    function renderChats() {
        chatContainer.innerHTML = chatHistory.map(m => `<div class="message">${m}</div>`).join('');
    }

    function sendMessage() {
        const input = document.getElementById('userInput');
        if (input.value) {
            chatHistory.push(input.value);
            localStorage.setItem('myChats', JSON.stringify(chatHistory));
            renderChats();
            input.value = '';
        }
    }
    renderChats();
</script>
</body>
</html>
